
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<title>Surface Website</title>
	<link rel="stylesheet" href="style.css" />
	<link href="~/css/layout.css" rel="stylesheet" />
</head>
<body>

	<header id="site-header" class="header">

		<div class="logo" href="@Url.Action("Index", "Home")">ABC</div>
		<div class="container">
			<nav class="nav">
				<a href="@Url.Action("Index", "Home")">Home</a>
				<a href ="@Url.Action("Index", "About")">About Us</a>
				<a>Collections</a>

				<div class="nav-item">
					<a>Gallery ▾</a>
					<div class="sub-menu">
						<a href="@Url.Action("Index", "Book")">List Books</a>

						<!-- Maintenance with sub-submenu -->
						<div class="sub-item">
							<a>Maintenance ▸</a>

							<div class="sub-sub-menu">
								<a>Cleaning</a>
								<a>Repair</a>
								<a>Inspection</a>
							</div>
						</div>

						<a>Projects</a>
					</div>
				</div>


				<a>Contact</a>
				<a>Download Catalog</a>
			</nav>
		</div>
	</header>






	<main>
		<div class="container">
			@RenderBody()
		</div>
	</main>
	@RenderSection("Scripts", required: false)


	<footer class="site-footer">
		<p>© 2026 ABC. All rights reserved.</p>
	</footer>


	<script>
		const header = document.getElementById("site-header");
		const links = document.querySelectorAll(".nav a");

		window.addEventListener("scroll", () => {
			if (window.scrollY > 50) {
				header.classList.add("scrolled");

				// Stagger animation
				links.forEach((link, index) => {
					link.style.transitionDelay = `${index * 0.08}s`;
				});

			} else {
				header.classList.remove("scrolled");

				links.forEach(link => {
					link.style.transitionDelay = "0s";
				});
			}
		});
	</script>



</body>
</html>
