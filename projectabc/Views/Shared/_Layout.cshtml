<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>@ViewBag.Title - Admin Dashboard</title>

	<!-- Bootstrap CSS -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

	<!-- Bootstrap Icons -->
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

	<style>

		body {
			min-height: 100vh;
			background-color: #f8f9fa;
			padding-top: 56px;
		}

		/* Sidebar base */
		.sidebar {
			width: 250px;
			background-color: #212529;
		}

		/* Desktop sidebar */
		@@media (min-width: 768px) {
			.sidebar {
				position: fixed;
				top: 56px;
				left: 0;
				height: calc(100vh - 56px);
			}
		}

		/* Sidebar links */
		.sidebar .nav-link {
			color: #adb5bd;
		}

			.sidebar .nav-link:hover,
			.sidebar .nav-link.active {
				background-color: #343a40;
				color: #fff;
			}

		/* Main content */
		.content {
			padding: 20px;
		}

		/* Desktop content offset */
		@@media (min-width: 768px) {
			.content {
				margin-left: 250px;
			}
		}
	</style>
</head>
<body>



	<!-- Top Navbar -->
	<nav class="navbar navbar-dark bg-dark px-3 fixed-top">
		<!-- Mobile toggle -->
		<button class="btn btn-dark d-md-none" data-bs-toggle="offcanvas" data-bs-target="#sidebar">
			<i class="bi bi-list"></i>
		</button>

		<span class="navbar-brand mb-0 h1 ms-2">Admin Panel</span>

		<div class="dropdown ms-auto">
			<a class="text-white dropdown-toggle" href="#" data-bs-toggle="dropdown">
				<i class="bi bi-person-circle"></i> Admin
			</a>
			<ul class="dropdown-menu dropdown-menu-end">
				<li><a class="dropdown-item" href="#">Profile</a></li>
				<li><a class="dropdown-item" href="#">Settings</a></li>
				<li><hr class="dropdown-divider"></li>
				<li><a class="dropdown-item text-danger" href="#">Logout</a></li>
			</ul>
		</div>
	</nav>


	<div class="d-flex">

		<!-- Sidebar -->
		<aside id="sidebar"
			   class="sidebar offcanvas-md offcanvas-start p-3"
			   tabindex="-1">
			<ul class="nav flex-column">
				<li class="nav-item">
					@Html.ActionLink(" Dashboard", "Index", "Dashboard",
					null, new { @class = "nav-link bi bi-speedometer2 active" })
				</li>
				<li class="nav-item">
					@Html.ActionLink(" Books", "Index", "Book",
										null, new { @class = "nav-link bi bi-people" })
				</li>
				<li class="nav-item">
					@Html.ActionLink(" Reports", "Index", "Reports",
										null, new { @class = "nav-link bi bi-bar-chart" })
				</li>
				<li class="nav-item">
					@Html.ActionLink(" Settings", "Index", "Settings",
										null, new { @class = "nav-link bi bi-gear" })
				</li>
			</ul>
		</aside>


		<!-- Main Content -->
		<main class="flex-fill content">
			@RenderBody()
		</main>
	</div>

	<!-- Bootstrap JS -->
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

	@RenderSection("Scripts", required: false)
</body>
</html>
``